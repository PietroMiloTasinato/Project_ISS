QActor display context ctx_ioport {

    [# var DisplayValue = "none" #]

    State wait initial {
        updateResource [# "display(service_working)" #]
    }

    Transition t0
        whenEvent show_hold_state -> showHold
        whenEvent show_service_status -> showService


    State showHold {

        onMsg(
            show_hold_state :
            show_hold_state(STATE)
        ) {
            [#
                DisplayValue =
                    "display(hold,${payloadArg(0)})"
            #]
        }

        println("$DisplayValue") color magenta

        updateResource [# DisplayValue #]
    }

    Goto wait


    State showService {

        onMsg(
            show_service_status :
            show_service_status(STATUS)
        ) {
            [#
                DisplayValue =
                    "display(service,${payloadArg(0)})"
            #]
        }

        println("$DisplayValue") color magenta

        updateResource [# DisplayValue #]
    }

    Goto wait
}

